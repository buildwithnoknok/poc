{
  "id": "two-button-box-v1",
  "name": "Two-Button Box",
  "version": "1.0.0",
  "author": "buildwithnoknok",
  "brain_type": "pico_w",
  "price": 0.0,
  "setup_pattern": "Setup 1 (I2C only)",
  "description": "Two buttons — OK and Cancel — with sound and light. During setup the app asks you to press the button you want for each, so it knows which is which. (Includes a Knob used for factory reset.)",

  "modules_required": [
    { "type": "led_button", "count": 2 },
    { "type": "buzzer",     "count": 1 },
    { "type": "knob",       "count": 1 }
  ],

  "module_firmware": {
    "led_button": { "version": "1.0.0", "url": "https://github.com/buildwithnoknok/module-I2C-ledbutton/releases/download/v1.0.0/ledbutton_firmware.bin" },
    "buzzer":     { "version": "3.1.0", "url": "https://github.com/buildwithnoknok/module-I2C-buzzer/releases/download/v3.1.0/buzzer_firmware.bin" },
    "knob":       { "version": "1.5.0", "url": "https://github.com/buildwithnoknok/module-I2C-knob/releases/download/v1.5.0/knob_firmware.bin" }
  },

  "files": [
    {
      "dest": "product.py",
      "url": "https://raw.githubusercontent.com/buildwithnoknok/poc/main/scripts/two_button_box.py",
      "version": "1.0.0",
      "required": true
    }
  ],

  "3d_files": [],
  "assembly_guide": [
    "Connect both LED Buttons, the Buzzer and the Knob to the PicoHub I2C ports.",
    "Plug the Pico into power.",
    "Run setup in the noknok app — it will ask you to press the OK and Cancel buttons."
  ],

  "roles": [
    { "id": "ok_button",     "module_type": "led_button", "prompt": "Press the button you want to use for OK" },
    { "id": "cancel_button", "module_type": "led_button", "prompt": "Press the button you want to use for Cancel" }
  ],

  "config_schema": []
}
